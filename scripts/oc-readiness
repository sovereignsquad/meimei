#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

critical_count=0
warn_count=0

section() {
  printf '\n== %s ==\n' "$1"
}

pass() {
  printf 'PASS: %s\n' "$1"
}

warn() {
  warn_count=$((warn_count + 1))
  printf 'WARN: %s\n' "$1"
}

critical() {
  critical_count=$((critical_count + 1))
  printf 'CRITICAL: %s\n' "$1"
}

run_and_capture() {
  local label="$1"
  shift
  local tmp
  tmp="$(mktemp)"
  section "$label"
  if "$@" >"$tmp" 2>&1; then
    cat "$tmp"
    rm -f "$tmp"
    return 0
  fi
  cat "$tmp"
  rm -f "$tmp"
  return 1
}

contains_text() {
  local pattern="$1"
  local file="$2"
  if command -v rg >/dev/null 2>&1; then
    rg -q "$pattern" "$file"
    return
  fi
  grep -qE "$pattern" "$file"
}

section "Readiness gate"
echo "Repository: $repo_root"
echo "Policy: fail on any CRITICAL condition."

if run_and_capture "Config validation" "$repo_root/scripts/oc" config validate; then
  pass "Config is valid."
else
  critical "Config validation failed."
fi

status_out="$(mktemp)"
section "Status probe"
if "$repo_root/scripts/oc-status" >"$status_out" 2>&1; then
  cat "$status_out"
if contains_text "Runtime: running" "$status_out"; then
    pass "Gateway runtime reported as running."
  else
    warn "Gateway runtime line not detected in status output."
  fi
else
  cat "$status_out"
  critical "Status command failed."
fi
rm -f "$status_out"

doctor_out="$(mktemp)"
section "Doctor probe"
if "$repo_root/scripts/oc-doctor" --non-interactive >"$doctor_out" 2>&1; then
  cat "$doctor_out"
  if contains_text "CRITICAL:" "$doctor_out"; then
    critical "Doctor reported CRITICAL findings."
  else
    pass "Doctor did not report CRITICAL findings."
  fi
else
  cat "$doctor_out"
  critical "Doctor command failed."
fi
rm -f "$doctor_out"

section "Result"
echo "Critical findings: $critical_count"
echo "Warnings: $warn_count"

if [ "$critical_count" -gt 0 ]; then
  echo "READINESS: FAIL"
  exit 1
fi

echo "READINESS: PASS"

#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
uid="$(id -u)"
dashboard_label="${MEIMEI_DASHBOARD_LABEL:-com.agent.meimei.dashboard-ui}"
watchdog_label="${MEIMEI_DASHBOARD_WATCHDOG_LABEL:-com.agent.meimei.dashboard-health}"
proxy_label="com.agent.meimei.dashboard-proxy"
if [[ -n "${PORT:-}" ]]; then
  dashboard_port="$PORT"
else
  dashboard_port="$(node "${ROOT_DIR}/config/print-dashboard-default-port.mjs")"
fi
health_url="${MEIMEI_DASHBOARD_HEALTH_URL:-http://127.0.0.1:${dashboard_port}/api/health}"
logs_dir="${HOME}/.meimei/logs"

echo "Dashboard UI label: $dashboard_label"
echo "Proxy label:        $proxy_label"
echo "Watchdog label:     $watchdog_label"
echo
echo "Dashboard UI launchctl:"
launchctl print "gui/$uid/$dashboard_label" 2>/dev/null || echo "Dashboard UI service not loaded."
echo
echo "Proxy launchctl:"
launchctl print "gui/$uid/$proxy_label" 2>/dev/null || echo "Proxy service not loaded."
echo
echo "Watchdog launchctl:"
launchctl print "gui/$uid/$watchdog_label" 2>/dev/null || echo "Watchdog service not loaded."
echo
echo "Health probe: $health_url"
if curl -fsS --max-time 5 "$health_url" >/dev/null 2>&1; then
  echo "Health: PASS"
else
  echo "Health: FAIL"
fi
echo
echo "Logs (canonical):"
echo "  $logs_dir/dashboard-ui.log"
echo "  $logs_dir/dashboard-ui.err"
echo "  $logs_dir/dashboard-proxy.log"
echo "  $logs_dir/dashboard-proxy.err"
echo "  $logs_dir/dashboard-health.log"
echo "  $logs_dir/dashboard-health.err"

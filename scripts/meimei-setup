#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DOMAIN_URL="${MEIMEI_PUBLIC_URL:-https://meimei.localhost:8443/dashboard/}"

"${ROOT_DIR}/scripts/meimei-domain" restart

if command -v open >/dev/null 2>&1; then
  open "${DOMAIN_URL}" >/dev/null 2>&1 || true
fi

echo "Ready: ${DOMAIN_URL}"

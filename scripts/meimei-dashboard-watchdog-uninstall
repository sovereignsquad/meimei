#!/usr/bin/env bash
set -euo pipefail

uid="$(id -u)"
plist_dir="$HOME/Library/LaunchAgents"

for label in \
  com.agent.meimei.dashboard-health \
  com.agent.meimei.dashboard-ui \
  com.agent.meimei.dashboard-proxy \
  com.agent.meimei.dashboard; do
  f="$plist_dir/${label}.plist"
  launchctl bootout "gui/${uid}" "$f" 2>/dev/null || true
  rm -f "$f"
done

# Retired namespace (optional cleanup)
for f in \
  "$plist_dir/ai.openclaw.meimei.dashboard-health.plist" \
  "$plist_dir/ai.openclaw.meimei.dashboard-ui.plist" \
  "$plist_dir/ai.openclaw.meimei.dashboard-proxy.plist"; do
  launchctl bootout "gui/${uid}" "$f" 2>/dev/null || true
  rm -f "$f"
done

echo "Uninstalled MeiMei dashboard/proxy/health LaunchAgents (and legacy names if present)."

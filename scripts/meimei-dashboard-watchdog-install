#!/usr/bin/env bash
# Canonical MeiMei stack: HTTPS proxy + dashboard UI + interval health probe.
# (Former separate dashboard+watchdog-only install is unified to avoid duplicate LaunchAgents on the same port.)
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

echo "Installing MeiMei platform LaunchAgents (see docs/operations/meimei-platform-launchd.v1.md)…" >&2
"$repo_root/scripts/meimei-domain" install
"$repo_root/scripts/meimei-openclaw-dashboard-watchdog-install.sh"
echo "Labels: com.agent.meimei.dashboard-ui, com.agent.meimei.dashboard-proxy, com.agent.meimei.dashboard-health"
